# ── Game It — variáveis de ambiente ──────────────────────
# Copie este arquivo para `.env` e preencha os valores.
#   Windows (PowerShell):  Copy-Item .env.example .env

# Banco de dados PostgreSQL (obrigatório)
# Ex.: postgresql://usuario:senha@localhost:5432/gameit
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gameit

# Chave secreta das sessões Flask (obrigatório em produção)
# Gere uma com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-aleatoria

# Steam (opcional — necessário para sincronizar biblioteca e status online)
STEAM_API_KEY=
STEAM_ID=

# Google Gemini (opcional — necessário para os guias com IA)
GEMINI_API_KEY=

# Cookies seguros (1 = somente HTTPS). Deixe 0 em desenvolvimento.
COOKIE_SECURE=0

# Origens permitidas para CORS em desenvolvimento (SPA Vite)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
